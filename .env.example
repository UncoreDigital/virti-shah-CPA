# ---------------------------------------------------------------------------
# Contact form (Resend) — copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored, so secrets never get committed.
# ---------------------------------------------------------------------------

# API key from Account A's Resend dashboard (Settings → API Keys).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address. MUST be on a domain you have VERIFIED in Account A's Resend
# (Domains → Add Domain → add the DNS records). Recommended: verify virtishahcpa.com
# so mail comes from the client's own domain (best deliverability).
# Format: "Display Name <address@your-verified-domain.com>"
CONTACT_FROM_EMAIL="Virti Shah CPA Website <noreply@virtishahcpa.com>"

# Where leads are delivered — the client's inbox (Account B). Any address works;
# recipients do NOT need to be verified in Resend.
CONTACT_TO_EMAIL=info@virtishahcpa.com
